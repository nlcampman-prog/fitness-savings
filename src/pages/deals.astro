---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const articles = Object.values(import.meta.glob('../content/articles/*.mdx', { eager: true }));
const allArticles = articles.sort((a: any, b: any) => new Date(b.frontmatter?.pubDate || 0).getTime() - new Date(a.frontmatter?.pubDate || 0).getTime());
---

<BaseLayout title="All Deals" description="Browse all fitness and recovery deals. Discount codes for supplements, workout gear, and recovery products.">
  <div class="container">
    <div class="category-header">
      <h1>All Deals</h1>
      <p>Every discount code and deal we've curated, sorted by latest first.</p>
    </div>
    <div class="card-grid">
      {allArticles.map((article: any) => {
        const { title, description, pubDate, category } = article.frontmatter;
        const slug = (article.file?.split('/')?.pop()?.replace(/\.(mdx|md)$/, '')) || '';
        return <ArticleCard title={title} description={description} url={`/articles/${slug}/`} category={category} date={pubDate} />;
      })}
    </div>
  </div>
</BaseLayout>